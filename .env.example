# Salin file ini menjadi .env dan isi nilainya

# URL database (opsional — saat ini model disimpan di .pkl, bukan DB)
DATABASE_URL=

# Path ke file model ML yang di-generate oleh ml/train.py
ML_MODEL_PATH=backend/models/ml_models.pkl

# URL frontend (dipakai backend untuk konfigurasi CORS)
FRONTEND_URL=http://localhost:5173

# URL backend API (dipakai frontend Vite)
VITE_API_URL=http://localhost:8000/api
